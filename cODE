--third move
local function ShadowSlamvVFX()
	--spawn vfx
	local Shockwave = BossVFX:FindFirstChild('ShadowSlam'):Clone()
	local Smash = BossVFX:FindFirstChild('Smash'):Clone()
	local Db = BossVFX:FindFirstChild('Debris'):Clone()
	local SmashSFX = BossVFX.Parent.SFX:FindFirstChild('Smash'):Clone()
	Shockwave.Parent = workspace.FX
	Shockwave:PivotTo(Boss.HumanoidRootPart.CFrame)
	Smash.Parent = workspace.FX
	Smash:PivotTo(Boss.HumanoidRootPart.CFrame)
	for i, VFX in ipairs(Shockwave:GetChildren()) do
	local ShockwaveTween = TweenService:Create(VFX,TweenInfo.new(1.5,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Size = Vector3.new(50,20,50)})
	local TransparencyTween = TweenService:Create(VFX,TweenInfo.new(1.5,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1})
	ShockwaveTween:Play()
	TransparencyTween:Play()
	end
	local SmashTween = TweenService:Create(Smash.Base,TweenInfo.new(1.5,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Size = Vector3.new(50,7,50)})
	SmashTween:Play()
	for i, v in pairs(Smash.Base:GetChildren()) do
		local TransparencyTween = TweenService:Create(v,TweenInfo.new(1.5,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1})
		TransparencyTween:Play()
	end
	
	Db.Parent = workspace.FX
	Db.CFrame = Boss.HumanoidRootPart.CFrame
	SmashSFX.Parent = Boss.HumanoidRootPart
	SmashSFX:Play()
	Debris:AddItem(SmashSFX,4)
	Debris:AddItem(Shockwave,4)
	Debris:AddItem(Smash,4)
	Debris:AddItem(Db,4)
end

