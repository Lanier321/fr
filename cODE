--track closest player
local function GetClosestPlayer()
	local ClosestPlayer
	local ClosestDistance = math.huge
	for _, Player in ipairs(Players:GetPlayers()) do
	local Character = Player.Character
		if Character then
			local Humanoid = Character:FindFirstChild("Humanoid")
			local Root = Character:FindFirstChild("HumanoidRootPart")
			if Humanoid and Root and Humanoid.Health > 0 then
				local Distance =
					(Root.Position - Boss.HumanoidRootPart.Position).Magnitude

				if Distance < ClosestDistance then
					ClosestDistance = Distance
					ClosestPlayer = Character
				end

			end

		end

	end

	if ClosestDistance <= AGGRO_RADIUS then
		return ClosestPlayer, ClosestDistance
	end

	return nil, ClosestDistance

end
--damae players function used for all damage
local function DamagePlayers(Size, Offset, Damage)

	local OverlapParams = OverlapParams.new()
	OverlapParams.FilterType = Enum.RaycastFilterType.Exclude
	OverlapParams.FilterDescendantsInstances = {Boss}

	local Parts = workspace:GetPartBoundsInBox(
		Root.CFrame * Offset,
		Size,
		OverlapParams
	)

	local HitCharacters = {}

	for _, Part in ipairs(Parts) do

		local Character = Part:FindFirstAncestorOfClass("Model")

		if Character
			and not HitCharacters[Character]
			and Players:GetPlayerFromCharacter(Character) then

			HitCharacters[Character] = true

			local Result = CombatService.Hit(
				Boss,
				Character,
				Damage,
				{
					BlockDamage = Damage,
					CanBlockBreak = true
				}
			)

			if Result == "Hit" then

				DamageIndicator.ShowDamage(Character, Damage)
				StunModule.Stun(Character,.45)

			elseif Result == "BlockBroken" then

				DamageIndicator.ShowDamage(Character, Damage)
				StunModule.Stun(Character,.45)

			end

		end

	end

end
--so the player cant get behind the boss
local function FaceTarget(Target, TurnSpeed)

	if not Target
		or not Target:FindFirstChild("HumanoidRootPart") then
		return
	end

	TurnSpeed = TurnSpeed or 0.25

	local Goal = CFrame.lookAt(
		Root.Position,
		Vector3.new(
			Target.HumanoidRootPart.Position.X,
			Root.Position.Y,
			Target.HumanoidRootPart.Position.Z
		)
	)

	Root.CFrame = Root.CFrame:Lerp(Goal, TurnSpeed)
end

--1st skill
local function DashSlash(Target)

	Attacking = true
	DashSlashOnCD = true

	CombatService.EnableHyperArmor(
		Boss,
		1.5
	)

	DashTrack:Play()

	task.wait(.3)

	local Goal =
		Target.HumanoidRootPart.Position 
--tween to target location
	local Tween =
		TweenService:Create(
			Root,
			TweenInfo.new(.4),
			{
				CFrame = CFrame.new(Goal)
			}
		)

	Tween:Play()
	
	Tween.Completed:Wait()

	DamagePlayers(
		Vector3.new(8,6,10),
		CFrame.new(0,0,-4),
		15
	)

	task.wait(1)
	--debounce

	Attacking = false
	task.delay(DashSlashCooldown,function()
		DashSlashOnCD = false
	end)

end

