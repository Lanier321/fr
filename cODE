--teleport to players so they cannot run
local function TeleportToPlayer(Target)

	LastTeleport = tick()

	local Position =
		Target.HumanoidRootPart.Position

	local RandomOffset = Vector3.new(math.random(-8,8),0,math.random(-8,8))

	Root.CFrame = CFrame.new(Position + RandomOffset)
	
	task.wait(.15)

	DashSlash(Target)
end
--basic m1 with air combos
local function M1Attack(Target)

	if M1OnCD then
		return
	end

	local Direction = (Target.HumanoidRootPart.Position - Root.Position).Unit
	local Facing = Root.CFrame.LookVector:Dot(Direction)

	if Facing < 0.5 then
		return
	end

	M1OnCD = true
	Attacking = true

	local CurrentTime = tick()

	if CurrentTime - PrevTime >= 2 then
		Animation = 1
		Combo = 1
	else
		Animation += 1
		Combo += 1

		if Animation > #LoadedTracks then
			Animation = 1
		end
	end

	PrevTime = CurrentTime

	for _, Track in ipairs(LoadedTracks) do
		if Track.IsPlaying then
			Track:Stop(0.05)
		end
	end

	local Track = LoadedTracks[Animation]
	if Track then
		Track:Play()
	end

	task.wait(.15)

	local SlashSFX = BossSFX.Slash:Clone()
	SlashSFX.Parent = Root
	SlashSFX:Play()

	Debris:AddItem(SlashSFX,2)

	local HitSomeone = false

	local Overlap = OverlapParams.new()
	Overlap.FilterType = Enum.RaycastFilterType.Exclude
	Overlap.FilterDescendantsInstances = {Boss}

	local Parts = workspace:GetPartBoundsInBox(

		Root.CFrame * CFrame.new(0,0,-4),

		Vector3.new(7,6,8),

		Overlap

	)

	local HitCharacters = {}

	for _,Part in ipairs(Parts) do

		local Character =
			Part:FindFirstAncestorOfClass("Model")

		if Character
			and not HitCharacters[Character]
			and Players:GetPlayerFromCharacter(Character) then

			HitCharacters[Character] = true
			--I use this as my service to determine combat states

			local Result = CombatService.Hit(

				Boss,

				Character,

				6 + Combo,

				{
					BlockDamage = 6 + Combo,
					CanBlockBreak = true
				}

			)

			if Result == "Hit" then

				HitSomeone = true

				DamageIndicator.ShowDamage(Character,6 + Combo)

				StunModule.Stun(Character,1.2)

				if Boss:GetAttribute("Airborne") then

					AirCombo += 1

					CombatService.AirM1(
						Boss,
						Character,
						AirCombo
					)

					if AirCombo >= MaxAirCombo then

						AirCombo = 0

						Boss:SetAttribute("DoingAirCombo",false)

					end

				else

					if Animation >= 4 then

						if math.random(1,100) <= 60 then

							Boss:SetAttribute("DoingAirCombo",true)
							Boss:SetAttribute('Airborne',true)


							AirCombo = 0
							Combo = 0
							CombatService.Uptilt(
								Boss,
								Character
							)

						else

							KnockbackModule.RagdollWithKnockback(

								Root,
								Character.Humanoid,
								Character,
								Character.HumanoidRootPart

							)

						end

					end

				end

			elseif Result == "BlockBroken" then

				DamageIndicator.ShowDamage(Character,6+Combo)

				StunModule.Stun(Character,1.2)
				
				Boss:SetAttribute("DoingAirCombo",false)
				AirCombo = 0

			elseif Result == "PerfectBlocked" then
               StunModule.PerfectBlocked(Boss)
				Attacking = false
				M1OnCD = false
				Boss:SetAttribute("DoingAirCombo",false)
				AirCombo = 0
				return

			end

		end

	end

	if Combo >= MaxCombo then
		task.wait(1.5)
		Combo = 0
		Animation = 0
	else
		task.wait(.1)
	end

	Attacking = false

	task.delay(M1Cooldown,function()
		M1OnCD = false
	end)

end

--Trying to make the boss less robotic with randomizing actions
local function RandomizeActions()

	local Choices = {}

	table.insert(Choices,{
		Name = "M1",
		Weight = 55
	})

	if not DashSlashOnCD then

		table.insert(Choices,{
			Name = "DashSlash",
			Weight = 20
		})

	end

	if not SpinSlashOnCD then

		table.insert(Choices,{
			Name = "SpinSlash",
			Weight = 15
		})

	end

	if not ShadowSlamOnCD then

		table.insert(Choices,{
			Name = "ShadowSlam",
			Weight = 10
		})

	end
	
	if Boss:GetAttribute("Airborne") then

		return "AirM1"

	end

	local Total = 0

	for _,Choice in ipairs(Choices) do
		Total += Choice.Weight
	end

	local Roll = math.random() * Total

	local Current = 0

	for _,Choice in ipairs(Choices) do

		Current += Choice.Weight

		if Roll <= Current then
			return Choice.Name
		end

	end

	return "M1"

end

--core loop
while Humanoid.Health > 0 do

	task.wait(0.1)

	if Attacking
		or Boss:GetAttribute("Disorientated")
		or Boss:GetAttribute("Stunned") then

		if WalkTrack.IsPlaying then
			WalkTrack:Stop(.15)
		end

		continue
	end
	
	local Target,Distance = GetClosestPlayer()


	if Distance > AGGRO_RADIUS then

		Aggroed = false

		Humanoid:MoveTo(Root.Position)

		if WalkTrack.IsPlaying then
			WalkTrack:Stop(.15)
		end

		continue
	end

	if not Aggroed then

		Aggroed = true

		print("Igris has aggroed!")
		-- I aint doin no cutscene gng
	end

	FaceTarget(Target, .2)
	print(Target)

	local TargetRoot = Target:FindFirstChild("HumanoidRootPart")
	local TargetHumanoid = Target:FindFirstChild("Humanoid")

	if not TargetRoot
		or not TargetHumanoid
		or TargetHumanoid.Health <= 0 then
		continue
	end

	local Offset = Root.CFrame.RightVector * math.random(-4,4)

	if not Attacking then
		print('WALK')
		Humanoid:MoveTo(TargetRoot.Position + Offset)
		if not WalkTrack.IsPlaying then
		WalkTrack:Play()
		end
	end

	if Boss:GetAttribute("DoingAirCombo") then

		M1Attack(Target)

		task.wait(.2)

		continue

	end
	-- Heres how the boss determines what moves to do after randomizing actions

	if Distance <= 6 then

		Humanoid:MoveTo(Root.Position)

		if WalkTrack.IsPlaying then
			WalkTrack:Stop(.15)
		end

		local Action = RandomizeActions()

		if Action == "M1" then

			M1Attack(Target)

		elseif Action == "DashSlash" then

			DashSlash(Target)

		elseif Action == "SpinSlash" then

			SpinningSlash(Target)

		elseif Action == "ShadowSlam" then

			ShadowSlam(Target)

		end

	elseif Distance <= 25 then

		if not DashSlashOnCD then

			DashSlash(Target)

		else

			Humanoid:MoveTo(TargetRoot.Position)

		end

	elseif Distance <= 40 then

		Humanoid:MoveTo(TargetRoot.Position)

	else

		if tick() - LastTeleport > 6 then

			TeleportToPlayer(Target)

		else

			Humanoid:MoveTo(TargetRoot.Position)

		end

	end

end
